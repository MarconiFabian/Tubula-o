{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "A construction project containing piping data, annotations, and production history.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "pipes": { "type": "array", "items": { "type": "object" } },
        "annotations": { "type": "array", "items": { "type": "object" } },
        "location": { "type": "string" },
        "client": { "type": "string" },
        "secondaryImage": { "type": "string" },
        "mapImage": { "type": "string" },
        "userId": { "type": "string" },
        "dailyProduction": { "type": "array", "items": { "type": "object" } },
        "activityDate": { "type": "string" },
        "deadlineDate": { "type": "string" },
        "projectCalendar": { "type": "object" }
      },
      "required": ["id", "name", "updatedAt", "userId"]
    }
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Storage for individual construction projects."
    }
  }
}
